JOBHUNT_ENV=development
JOBHUNT_DATABASE_URL=sqlite:///./jobhunt.db
JOBHUNT_LOG_LEVEL=INFO

ADZUNA_APP_ID=
ADZUNA_APP_KEY=

USAJOBS_EMAIL=
USAJOBS_API_KEY=

REED_API_KEY=

# Groq (free LLM API) for the CV-based profile builder. Get a key at https://console.groq.com
# Leave blank to use the deterministic offline profile builder instead.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
